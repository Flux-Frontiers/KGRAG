{
  "tests": [
    {
      "name": "gutenberg_query",
      "input": {
        "query": "Marcus Aurelius on virtue and reason",
        "corpus": "gutenberg",
        "k": 5
      },
      "timeout": 60000
    },
    {
      "name": "all_corpora_query",
      "input": {
        "query": "glycolysis ATP production",
        "corpus": "all",
        "k": 3,
        "semantic_floor": 0.0
      },
      "timeout": 60000
    },
    {
      "name": "missing_query_returns_error_field",
      "input": {"corpus": "gutenberg"},
      "timeout": 10000
    }
  ],
  "config": {
    "gpuTypeId": "NVIDIA GeForce RTX 4090",
    "gpuCount": 1,
    "env": [
      {
        "key": "KG_VOLUME",
        "value": "/tmp/empty_kgdata"
      }
    ],
    "allowedCudaVersions": [
      "12.8", "12.7", "12.6", "12.5", "12.4",
      "12.3", "12.2", "12.1", "12.0"
    ]
  }
}
