# .env.example — copy to .env and fill in values
#
# Absolute paths to local corpus directories
GUTENBERG_CORPUS=/Users/yourname/repos/gutenberg_kg/corpus
METABO_REPO=/Users/yourname/repos/Metabo_kg

# Shared secret for request auth (optional — leave blank to disable)
HANDLER_SECRET=

# Synthesis (optional — leave blank to disable)
VLLM_ENDPOINT_URL=http://host.docker.internal:11434
VLLM_MODEL=qwen3:4b
RUNPOD_API_KEY=ollama
